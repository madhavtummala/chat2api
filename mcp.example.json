{
  "servers": [
    {
      "label": "weather",
      "transport": "stdio",
      "command": "python",
      "args": ["path/to/weather_server.py"]
    },
    {
      "label": "search",
      "transport": "http",
      "url": "https://example.com/mcp",
      "headers": { "Authorization": "Bearer <token>" }
    }
  ]
}
