# chat2api configuration — copy to `.env` and edit. All vars use the CHAT2API_ prefix.

# ---- HTTP server ----
CHAT2API_HOST=0.0.0.0
CHAT2API_PORT=9000
CHAT2API_LOG_LEVEL=info
# Comma-separated bearer keys clients must send. Leave empty to disable auth.
CHAT2API_API_KEYS=

# ---- Provider ----
# One of: expressai | perplexity | googleaimode
# googleaimode needs no login; expressai/perplexity require a browser session.
CHAT2API_PROVIDER=googleaimode

# ---- MCP (optional) ----
# JSON file describing MCP servers whose tools are advertised to the model.
# Defaults to mcp.json in the CWD (auto-loaded if present); override the path here.
# CHAT2API_MCP_CONFIG_PATH=mcp.json

# ---- Responses API (optional) ----
# Expose the stateful /v1/responses endpoint (agentic loop + server-side MCP).
# CHAT2API_ENABLE_RESPONSES=true
# Max model<->tool round-trips within a single /v1/responses request.
# CHAT2API_MAX_AGENT_TURNS=6

# ---- Browser ----
# Set to false for the first run so you can log in manually; the login is saved.
CHAT2API_HEADLESS=true
CHAT2API_USER_DATA_DIR=.browser_profile
# Alternative to USER_DATA_DIR: path to a Playwright storage_state JSON export.
# CHAT2API_STORAGE_STATE=auth.json
CHAT2API_MAX_CONCURRENCY=2
# Recycle a tab after this many uses (0 = never). Tabs always recycle on error.
CHAT2API_MAX_TAB_USES=200
CHAT2API_NAV_TIMEOUT_MS=45000

# ---- Provider base URLs ----
CHAT2API_EXPRESSAI_BASE_URL=https://app.expressai.com
CHAT2API_PERPLEXITY_BASE_URL=https://www.perplexity.ai
CHAT2API_RESPONSE_TIMEOUT_S=180
CHAT2API_POLL_INTERVAL_S=0.2
